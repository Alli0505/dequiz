# Copy this file to `.env.local` and fill in the two values from your Supabase
# project (Dashboard → Project Settings → API). `.env.local` is gitignored.
#
# Leave these empty (or omit the file) to run DeQuiz in LOCAL mode — no backend,
# progress and leaderboard stored in the browser's localStorage.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
